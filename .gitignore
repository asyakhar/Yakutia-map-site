```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js
*.ts

# Editor files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Environment
.env
.env.local
*.env.*

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Coverage
coverage/
htmlcov/
.coverage

# Temporary files
*.tmp
*.temp

# OS generated files
.DS_Store
Thumbs.db

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```